{
  "manifest_version": 3,
  "name": "GGMPlus",
  "version": "1.1.0",
  "description": "GGM 출석체크, 빠른 이동, 글 임시저장, 관심 알림을 제공하는 확장 프로그램",
  "permissions": [
    "alarms",
    "cookies",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://ggm.gondr.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GGMPlus"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ggm.gondr.net/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "attendance.html",
        "attendance-settings.html",
        "launcher.html",
        "launcher-settings.html",
        "alerts.html",
        "alerts-settings.html",
        "automation.html",
        "automation-settings.html",
        "drafts.html",
        "drafts-settings.html",
        "site.html",
        "site-settings.html",
        "activity.html",
        "settings.html",
        "home-settings.html",
        "ui.css",
        "assets/ggmplus-title.png",
        "icons/icon48.png"
      ],
      "matches": [
        "https://ggm.gondr.net/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
