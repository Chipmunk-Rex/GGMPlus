{
  "manifest_version": 3,
  "name": "GGMPlus",
  "version": "1.1.0",
  "description": "GGM 출석체크, 빠른 이동, 글 임시저장, 관심 알림을 제공하는 확장 프로그램",
  "permissions": [
    "alarms",
    "cookies",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://ggm.gondr.net/*"
  ],
  "background": {
    "scripts": [
      "shared/constants.js",
      "shared/message-types.js",
      "shared/ggm-url.js",
      "background/config.js",
      "background/storage.js",
      "background/activity.js",
      "background/notifications.js",
      "background/auth.js",
      "background/utility-monitor.js",
      "background/automation.js",
      "background/attendance.js",
      "background/messages.js",
      "background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GGMPlus"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ggm.gondr.net/*"
      ],
      "js": [
        "shared/message-types.js",
        "shared/dom.js",
        "content/token-watcher.js",
        "content/drafts.js",
        "content/read-posts.js",
        "content/dark-mode.js",
        "content/floating-panel.js",
        "content/daily-report-fill.js",
        "content/api-bridge.js",
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "attendance.html",
        "attendance-settings.html",
        "launcher.html",
        "launcher-settings.html",
        "alerts.html",
        "alerts-settings.html",
        "automation.html",
        "automation-settings.html",
        "drafts.html",
        "drafts-settings.html",
        "site.html",
        "site-settings.html",
        "activity.html",
        "settings.html",
        "home-settings.html",
        "ui.css",
        "assets/ggmplus-title.png",
        "icons/icon48.png"
      ],
      "matches": [
        "https://ggm.gondr.net/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ggmplus@chipmunk-rex",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
